# XP_DATA_DIR default: ./data
XP_DATA_DIR=/var/lib/xp/data

# XP_BIND default: 127.0.0.1:62416
XP_BIND=127.0.0.1:62416

# XP_XRAY_API_ADDR default: 127.0.0.1:10085
XP_XRAY_API_ADDR=127.0.0.1:10085

# XP_XRAY_HEALTH_INTERVAL_SECS default: 2
XP_XRAY_HEALTH_INTERVAL_SECS=2

# XP_XRAY_HEALTH_FAILS_BEFORE_DOWN default: 3
XP_XRAY_HEALTH_FAILS_BEFORE_DOWN=3

# XP_XRAY_RESTART_MODE default: none (none|systemd|openrc)
XP_XRAY_RESTART_MODE=none

# XP_XRAY_RESTART_COOLDOWN_SECS default: 30
XP_XRAY_RESTART_COOLDOWN_SECS=30

# XP_XRAY_RESTART_TIMEOUT_SECS default: 5
XP_XRAY_RESTART_TIMEOUT_SECS=5

# XP_XRAY_SYSTEMD_UNIT default: xray.service
XP_XRAY_SYSTEMD_UNIT=xray.service

# XP_XRAY_OPENRC_SERVICE default: xray
XP_XRAY_OPENRC_SERVICE=xray

# XP_CLOUDFLARED_HEALTH_INTERVAL_SECS default: 5
XP_CLOUDFLARED_HEALTH_INTERVAL_SECS=5

# XP_CLOUDFLARED_HEALTH_FAILS_BEFORE_DOWN default: 3
XP_CLOUDFLARED_HEALTH_FAILS_BEFORE_DOWN=3

# XP_CLOUDFLARED_RESTART_MODE default: none (none|systemd|openrc)
XP_CLOUDFLARED_RESTART_MODE=none

# XP_CLOUDFLARED_RESTART_COOLDOWN_SECS default: 30
XP_CLOUDFLARED_RESTART_COOLDOWN_SECS=30

# XP_CLOUDFLARED_RESTART_TIMEOUT_SECS default: 5
XP_CLOUDFLARED_RESTART_TIMEOUT_SECS=5

# XP_CLOUDFLARED_SYSTEMD_UNIT default: cloudflared.service
XP_CLOUDFLARED_SYSTEMD_UNIT=cloudflared.service

# XP_CLOUDFLARED_OPENRC_SERVICE default: cloudflared
XP_CLOUDFLARED_OPENRC_SERVICE=cloudflared

# XP_ADMIN_TOKEN_HASH default: empty (admin API disabled when empty)
XP_ADMIN_TOKEN_HASH=

# XP_NODE_NAME default: xp-node
XP_NODE_NAME=xp-node

# XP_ACCESS_HOST default: empty
XP_ACCESS_HOST=

# XP_API_BASE_URL default: https://127.0.0.1:62416
XP_API_BASE_URL=https://127.0.0.1:62416

# XP_ENDPOINT_PROBE_SKIP_SELF_TEST default: false
XP_ENDPOINT_PROBE_SKIP_SELF_TEST=false

# XP_QUOTA_POLL_INTERVAL_SECS default: 10
XP_QUOTA_POLL_INTERVAL_SECS=10

# XP_QUOTA_AUTO_UNBAN default: true
XP_QUOTA_AUTO_UNBAN=true

# XP_IP_GEO_ENABLED default: false
XP_IP_GEO_ENABLED=false

# XP_IP_GEO_ORIGIN default: https://api.country.is
XP_IP_GEO_ORIGIN=https://api.country.is
