{
	"name": "web",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite --host 127.0.0.1 --port 60080 --strictPort",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "biome check .",
		"format": "biome check --write .",
		"typecheck": "tsc -b",
		"test": "vitest run",
		"test:watch": "vitest",
		"storybook": "storybook dev -p 60081 --host 127.0.0.1 --no-open",
		"build-storybook": "storybook build",
		"test-storybook": "test-storybook --url http://127.0.0.1:60081 --ci --browsers chromium --failOnConsole --testTimeout 60000 --maxWorkers=2",
		"test:e2e": "playwright test"
	},
